<UserControl x:Class="ProjectBReadyWPF.Frontend.Views.Reports.ReportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="1200" d:DesignWidth="800"
             Background="{StaticResource MainBg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOPBAR -->
        <Grid Grid.Row="0" Margin="32,20" Background="{StaticResource CardBg}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.ColumnSpan="2" Height="1" Background="{StaticResource Border}" VerticalAlignment="Bottom"/>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Reports &amp; Analytics" Style="{StaticResource PageH1}"/>
                <TextBlock Text="Comprehensive summary of all relief operations" Style="{StaticResource PageSubtitle}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="⟳  Refresh" Style="{StaticResource BtnGhost}" Click="OnRefresh" Margin="0,0,8,0"/>
                <Button Content="🖨 Print" Style="{StaticResource BtnGhost}" Click="OnPrint" Margin="0,0,8,0"/>
                <Button Content="⬇ Export CSV" Style="{StaticResource BtnPrimary}" Click="OnExportCsv"/>
            </StackPanel>
        </Grid>

        <!-- PAGE BODY -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="32,28">

                <!-- KPI Cards (3-col) -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Shelters KPI -->
                    <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0,0,8,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="SHELTERS" Style="{StaticResource StatLabel}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="🏛️" FontSize="22"/>
                            </Grid>
                            <TextBlock Text="{Binding Summary.TotalShelters}" Style="{StaticResource StatValue}"/>
                            <TextBlock Text="{Binding Summary.ShelterNote}" FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Occupancy Rate KPI -->
                    <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="8,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="OCCUPANCY RATE" Style="{StaticResource StatLabel}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="📊" FontSize="22"/>
                            </Grid>
                            <TextBlock Text="{Binding Summary.OccupancyRateDisplay}" Style="{StaticResource StatValue}"/>
                            <TextBlock Text="{Binding Summary.OccupancyNote}" FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Expiring Items KPI -->
                    <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="8,0,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="EXPIRING ITEMS" Style="{StaticResource StatLabel}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="⚠️" FontSize="22"/>
                            </Grid>
                            <TextBlock Text="{Binding Summary.ExpiringCount}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource Red}"/>
                            <TextBlock Text="Within the next 30 days" FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── SECTION: SHELTER REPORT ── -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SHELTER REPORT" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Height="1" Background="{StaticResource Border}" Margin="12,0,0,0"/>
                </Grid>

                <Border Style="{StaticResource Card}" Margin="0,0,0,24" Padding="0">
                    <StackPanel>
                        <StackPanel Margin="18,18,18,14">
                            <TextBlock Text="Evacuation Shelter Summary" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Full status and capacity breakdown" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Height="1" Background="{StaticResource Border}"/>
                        
                        <Grid Margin="16,0,16,0" Background="{StaticResource TableHeaderBg}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SHELTER NAME" Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="1" Text="MAX CAP." Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="2" Text="CURRENT" Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="3" Text="AVAILABLE" Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="4" Text="OCCUPANCY" Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="5" Text="% FULL" Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="6" Text="STATUS" Style="{StaticResource TableHeader}"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource Border}"/>

                        <ItemsControl ItemsSource="{Binding ShelterRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="16,8,16,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource TableCellBold}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Max}" Style="{StaticResource TableCellMuted}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Current}" Style="{StaticResource TableCellMuted}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Available}" Style="{StaticResource TableCellBold}" Foreground="{Binding AvailableColor}"/>
                                        
                                        <!-- Progress bar -->
                                        <Grid Grid.Column="4" Margin="0,0,16,0" VerticalAlignment="Center">
                                            <Border Background="{StaticResource Border}" CornerRadius="3" Height="6"/>
                                            <Border Background="{Binding FillColor}" CornerRadius="3" Height="6"
                                                    HorizontalAlignment="Stretch" RenderTransformOrigin="0,0.5">
                                                <Border.RenderTransform>
                                                    <ScaleTransform ScaleX="{Binding FillPercent}"/>
                                                </Border.RenderTransform>
                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Column="5" Text="{Binding PctFull}" Style="{StaticResource TableCellBold}" Foreground="{Binding PctColor}"/>
                                        <Border Grid.Column="6" Background="{Binding StatusBadgeBg}"
                                                CornerRadius="20" Padding="10,3" BorderBrush="Transparent"
                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold" Foreground="{Binding StatusTextColor}"/>
                                        </Border>
                                        <Border Grid.ColumnSpan="7" Height="1" Background="{StaticResource Border}" VerticalAlignment="Bottom" Margin="0,8,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Totals Row -->
                        <Grid Margin="16,13,16,13" Background="{StaticResource TableHeaderBg}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TOTAL" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock Grid.Column="1" Text="{Binding ShelterTotals.TotalMax}" FontSize="13" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="{Binding ShelterTotals.TotalCurrent}" FontSize="13" FontWeight="Bold"/>
                            <TextBlock Grid.Column="3" Text="{Binding ShelterTotals.TotalAvailable}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Teal}"/>
                            <TextBlock Grid.Column="5" Text="{Binding ShelterTotals.OverallPct}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource Accent}"/>
                            <TextBlock Grid.Column="6" Text="—" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── SECTION: FOOD INVENTORY REPORT ── -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="FOOD INVENTORY REPORT" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Height="1" Background="{StaticResource Border}" Margin="12,0,0,0"/>
                </Grid>

                <Border Style="{StaticResource Card}" Margin="0,0,0,24" Padding="0">
                    <StackPanel>
                        <Grid Margin="18,18,18,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="🍚 Food Items" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Current stock levels and expiration" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="View Full Inventory" Style="{StaticResource BtnGhostSm}" VerticalAlignment="Center" Click="OnViewInventory"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource Border}"/>
                        
                        <Grid Margin="16,0,16,0" Background="{StaticResource TableHeaderBg}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ITEM NAME" Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="1" Text="QTY" Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="2" Text="EXPIRATION" Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="3" Text="DAYS LEFT" Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="4" Text="STATUS" Style="{StaticResource TableHeader}"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource Border}"/>

                        <ItemsControl ItemsSource="{Binding FoodReportRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="16,8,16,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource TableCellBold}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Qty}" Style="{StaticResource TableCellBold}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ExpiryDisplay}" Style="{StaticResource TableCellMuted}" Foreground="{Binding ExpiryColor}"/>
                                        
                                        <Border Grid.Column="3" Background="{Binding DaysBadgeBg}"
                                                CornerRadius="20" Padding="10,3" BorderBrush="Transparent"
                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DaysLeft}" FontSize="11" FontWeight="Bold" Foreground="{Binding DaysBadgeText}"/>
                                        </Border>
                                        <Border Grid.Column="4" Background="{Binding StatusBadgeBg}"
                                                CornerRadius="20" Padding="10,3" BorderBrush="Transparent"
                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding StatusLabel}" FontSize="11" FontWeight="Bold" Foreground="{Binding StatusTextColor}"/>
                                        </Border>
                                        <Border Grid.ColumnSpan="5" Height="1" Background="{StaticResource Border}" VerticalAlignment="Bottom" Margin="0,8,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Totals Row -->
                        <Grid Margin="16,13,16,13" Background="{StaticResource TableHeaderBg}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TOTAL" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock Grid.Column="1" Text="{Binding FoodTotal}" FontSize="13" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── SECTION: MEDICAL INVENTORY REPORT ── -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="MEDICAL INVENTORY REPORT" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                    <Border Grid.Column="1" Height="1" Background="{StaticResource Border}" Margin="12,0,0,0"/>
                </Grid>

                <Border Style="{StaticResource Card}" Margin="0,0,0,24" Padding="0">
                    <StackPanel>
                        <Grid Margin="18,18,18,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="💊 Medical Supplies" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Current medical stock" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="View Full Inventory" Style="{StaticResource BtnGhostSm}" VerticalAlignment="Center" Click="OnViewInventory"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource Border}"/>
                        
                        <Grid Margin="16,0,16,0" Background="{StaticResource TableHeaderBg}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ITEM NAME" Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="1" Text="QTY" Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="2" Text="DOSAGE" Style="{StaticResource TableHeader}"/>
                            <TextBlock Grid.Column="3" Text="RX REQUIRED" Style="{StaticResource TableHeader}"/>
                        </Grid>
                        <Border Height="1" Background="{StaticResource Border}"/>

                        <ItemsControl ItemsSource="{Binding MedReportRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="16,8,16,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Style="{StaticResource TableCellBold}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Qty}" Style="{StaticResource TableCellBold}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Dosage}" Style="{StaticResource TableCellMuted}"/>
                                        
                                        <Border Grid.Column="3" Background="{Binding RxBadgeBg}"
                                                CornerRadius="20" Padding="10,3" BorderBrush="Transparent"
                                                HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding RxLabel}" FontSize="11" FontWeight="Bold" Foreground="{Binding RxTextColor}"/>
                                        </Border>
                                        <Border Grid.ColumnSpan="4" Height="1" Background="{StaticResource Border}" VerticalAlignment="Bottom" Margin="0,8,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Totals Row -->
                        <Grid Margin="16,13,16,13" Background="{StaticResource TableHeaderBg}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TOTAL" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock Grid.Column="1" Text="{Binding MedTotal}" FontSize="13" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
