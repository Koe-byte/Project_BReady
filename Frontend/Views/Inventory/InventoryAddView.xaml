<UserControl x:Class="ProjectBReadyWPF.Frontend.Views.Inventory.InventoryAddView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="800"
             Background="{StaticResource MainBg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOPBAR -->
        <Grid Grid.Row="0" Margin="32,20" Background="{StaticResource CardBg}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Grid.ColumnSpan="2" Height="1" Background="{StaticResource Border}" VerticalAlignment="Bottom"/>
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Add Inventory Item" Style="{StaticResource PageH1}"/>
                <TextBlock Text="Add a new item to the relief inventory" Style="{StaticResource PageSubtitle}"/>
            </StackPanel>
            <Button Grid.Column="1" Content="← Back to Inventory"
                    Style="{StaticResource BtnGhost}" VerticalAlignment="Center"
                    Click="OnBackToInventory"/>
        </Grid>

        <!-- FORM BODY -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="32,36" HorizontalAlignment="Center" MaxWidth="600">

                <Border Style="{StaticResource Card}" Padding="0">
                    <StackPanel>

                        <!-- Card Header -->
                        <StackPanel Margin="28,24,28,18">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="HeaderIconFrame" Background="{StaticResource AccentLight}"
                                        CornerRadius="12" Width="44" Height="44"
                                        Padding="0" BorderBrush="Transparent" Margin="0,0,14,0">
                                    <TextBlock x:Name="HeaderIcon" Text="📦" FontSize="22"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="HeaderTitle" Text="Add Inventory Item" FontSize="18" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Text="Select a type then fill in the details" FontSize="13"
                                               Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        <Border Height="1" Background="{StaticResource Border}"/>

                        <!-- Card Body -->
                        <StackPanel Margin="28">

                            <!-- Type Toggle -->
                            <TextBlock Text="ITEM TYPE" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border x:Name="BtnFoodFrame" Grid.Column="0" Background="{StaticResource AccentLight}"
                                        BorderBrush="{StaticResource Accent}" BorderThickness="1"
                                        CornerRadius="12" Margin="0,0,5,0">
                                    <Button x:Name="BtnFood" Content="🍚  Food" Background="Transparent" BorderThickness="0"
                                            Foreground="{StaticResource Accent}" FontSize="14" FontWeight="Bold"
                                            Padding="12" Click="OnSelectFood"/>
                                </Border>
                                
                                <Border x:Name="BtnMedFrame" Grid.Column="1" Background="White"
                                        BorderBrush="{StaticResource Border}" BorderThickness="1"
                                        CornerRadius="12" Margin="5,0,0,0">
                                    <Button x:Name="BtnMed" Content="💊  Medical Supply" Background="Transparent" BorderThickness="0"
                                            Foreground="{StaticResource TextSecondary}" FontSize="14"
                                            Padding="12" Click="OnSelectMedical"/>
                                </Border>
                            </Grid>

                            <TextBlock Text="ITEM DETAILS" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextMuted}" Margin="0,0,0,6"/>
                            <Border Height="1" Background="{StaticResource Border}" Margin="0,0,0,14"/>

                            <!-- Item Name -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6">
                                    <Run Text="Item Name "/><Run Text="*" Foreground="{StaticResource Red}"/>
                                </TextBlock>
                                <TextBox x:Name="ItemNameEntry" FontSize="14" Padding="10,8"
                                         BorderBrush="{StaticResource Border}" BorderThickness="1"/>
                            </StackPanel>

                            <!-- Quantity -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6">
                                    <Run Text="Quantity "/><Run Text="*" Foreground="{StaticResource Red}"/>
                                </TextBlock>
                                <TextBox x:Name="ItemQtyEntry" Text="0" FontSize="14" Padding="10,8"
                                         BorderBrush="{StaticResource Border}" BorderThickness="1"/>
                            </StackPanel>

                            <!-- Food-only: Expiration Date -->
                            <StackPanel x:Name="FoodFields" Margin="0,0,0,16">
                                <TextBlock FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6">
                                    <Run Text="Expiration Date "/><Run Text="*" Foreground="{StaticResource Red}"/>
                                </TextBlock>
                                <DatePicker x:Name="ExpDatePicker" FontSize="14" Padding="10,8"
                                            BorderBrush="{StaticResource Border}" BorderThickness="1"/>
                            </StackPanel>

                            <!-- Medical-only fields -->
                            <StackPanel x:Name="MedFields" Visibility="Collapsed">
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="Dosage" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>
                                    <TextBox x:Name="DosageEntry" FontSize="14" Padding="10,8"
                                             BorderBrush="{StaticResource Border}" BorderThickness="1"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <CheckBox x:Name="RxCheckbox" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Prescription Required" FontSize="14"
                                               Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Error / Success messages -->
                            <Border x:Name="ErrorBorder" Style="{StaticResource AlertWarn}"
                                    Visibility="Collapsed" Margin="0,8,0,0" Padding="14">
                                <TextBlock x:Name="ErrorLabel" FontSize="13" Foreground="#991B1B" TextWrapping="Wrap"/>
                            </Border>
                            <Border x:Name="SuccessBorder" Background="#D1FAE5" BorderBrush="#6EE7B7"
                                    BorderThickness="1" CornerRadius="12" Padding="14"
                                    Visibility="Collapsed" Margin="0,8,0,0">
                                <TextBlock x:Name="SuccessLabel" FontSize="13" Foreground="#166534" TextWrapping="Wrap"/>
                            </Border>

                        </StackPanel>

                        <!-- Card Footer -->
                        <Border Height="1" Background="{StaticResource Border}"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="28,18">
                            <Button Content="✕ Cancel" Style="{StaticResource BtnGhost}" Click="OnCancel"/>
                            <Button Content="💾 Save Item" Style="{StaticResource BtnPrimary}" Margin="10,0,0,0" Click="OnSaveItem"/>
                        </StackPanel>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
