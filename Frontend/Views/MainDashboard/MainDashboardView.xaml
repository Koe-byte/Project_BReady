<UserControl x:Class="ProjectBReadyWPF.Frontend.Views.MainDashboard.MainDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="800"
             Background="{StaticResource MainBg}">
<Grid >
<Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>

      <!-- TOPBAR (.topbar) -->
      <Grid Grid.Row="0"
            Margin="32,20"
            Background="{StaticResource CardBg}"
             >
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <Border Grid.ColumnSpan="2"
                 Height="1"
                 Background="{StaticResource Border}"
                 VerticalAlignment="Bottom"/>
        <StackPanel Grid.Column="0" VerticalAlignment="Center">
          <TextBlock Text="Relief Operations Dashboard"
                 Style="{StaticResource PageH1}"/>
          <TextBlock Text="Real-time overview of evacuation shelters and relief goods"
                 Style="{StaticResource PageSubtitle}"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" Grid.Column="1"
                               VerticalAlignment="Center"
                              >
          <Button Content="⟳  Refresh"
                  Style="{StaticResource BtnGhost}"
                  Click="OnRefresh"/>
          <Button Content="+ Add Shelter"
                  Style="{StaticResource BtnPrimary}"
                  Click="OnAddShelter"/>
        </StackPanel>
      </Grid>

      <!-- PAGE BODY (.page-body) -->
      <ScrollViewer Grid.Row="1">
        <StackPanel Margin="32,28">

          <!-- Alert (.alert-warn) -->
          <Border Style="{StaticResource AlertWarn}" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="⚠️" VerticalAlignment="Center" FontSize="14"/>
              <TextBlock VerticalAlignment="Center" FontSize="13" Foreground="#92400E">
                    <Run Text="3 food items" FontWeight="Bold"/>
                    <Run Text=" are expiring within the next 7 days. Review Inventory →"/>
              </TextBlock>
            </StackPanel>
          </Border>

          <!-- Stat Cards (.stat-grid — 4 col) -->
          <Grid  
                Margin="0,0,0,28">
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <!-- Orange: evacuees -->
            <Border Grid.Column="0" Style="{StaticResource StatCard}">
              <StackPanel>
                <Border Background="{StaticResource AccentLight}"
                       CornerRadius="12" Width="44" Height="44"
                       Padding="0" BorderBrush="Transparent"
                       HorizontalAlignment="Left" Margin="0,0,0,14">
                  <TextBlock Text="👥" FontSize="20"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{Binding TotalEvacuees}" Style="{StaticResource StatValue}"/>
                <TextBlock Text="Total Evacuees" Style="{StaticResource StatLabel}"/>
                <TextBlock Text="{Binding TotalCapacity, StringFormat='of {0} total capacity'}" Style="{StaticResource StatSub}"/>
                <!-- bottom accent bar -->
                <Border Height="3" CornerRadius="2" Margin="0,12,-24,-22"
                         Background="{StaticResource Accent}"/>
              </StackPanel>
            </Border>
            <!-- Teal: shelters -->
            <Border Grid.Column="1" Style="{StaticResource StatCard}">
              <StackPanel>
                <Border Background="{StaticResource TealLight}"
                       CornerRadius="12" Width="44" Height="44"
                       Padding="0" BorderBrush="Transparent"
                       HorizontalAlignment="Left" Margin="0,0,0,14">
                  <TextBlock Text="🏛️" FontSize="20"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{Binding OpenShelters}" Style="{StaticResource StatValue}"/>
                <TextBlock Text="Open Shelters" Style="{StaticResource StatLabel}"/>
                <TextBlock Text="{Binding TotalShelters, StringFormat='{}{0} shelters total'}" Style="{StaticResource StatSub}"/>
                <Border Height="3" CornerRadius="2" Margin="0,12,-24,-22"
                         Background="{StaticResource Teal}"/>
              </StackPanel>
            </Border>
            <!-- Blue: items -->
            <Border Grid.Column="2" Style="{StaticResource StatCard}">
              <StackPanel>
                <Border Background="{StaticResource BlueLight}"
                       CornerRadius="12" Width="44" Height="44"
                       Padding="0" BorderBrush="Transparent"
                       HorizontalAlignment="Left" Margin="0,0,0,14">
                  <TextBlock Text="📦" FontSize="20"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{Binding ReliefItems, StringFormat='{}{0:N0}'}" Style="{StaticResource StatValue}"/>
                <TextBlock Text="Relief Items" Style="{StaticResource StatLabel}"/>
                <TextBlock Text="{Binding ItemTypes, StringFormat='{}{0} item types tracked'}" Style="{StaticResource StatSub}"/>
                <Border Height="3" CornerRadius="2" Margin="0,12,-24,-22"
                         Background="{StaticResource Blue}"/>
              </StackPanel>
            </Border>
            <!-- Red: dispatches -->
            <Border Grid.Column="3" Style="{StaticResource StatCard}">
              <StackPanel>
                <Border Background="{StaticResource RedLight}"
                       CornerRadius="12" Width="44" Height="44"
                       Padding="0" BorderBrush="Transparent"
                       HorizontalAlignment="Left" Margin="0,0,0,14">
                  <TextBlock Text="🚚" FontSize="20"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="{Binding DispatchCount}" Style="{StaticResource StatValue}"/>
                <TextBlock Text="Dispatches" Style="{StaticResource StatLabel}"/>
                <TextBlock Text="recent records" Style="{StaticResource StatSub}"/>
                <Border Height="3" CornerRadius="2" Margin="0,12,-24,-22"
                         Background="{StaticResource Red}"/>
              </StackPanel>
            </Border>
          </Grid>

          <!-- Two-col: Bar chart card + Donut card (.two-col) -->
          <Grid   Margin="0,0,0,20">
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="340"/></Grid.ColumnDefinitions>

            <!-- Bar chart card -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
              <StackPanel>
                <Grid Margin="18,18,18,0"  >
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0">
                    <TextBlock Text="Shelter Occupancy Overview" Style="{StaticResource CardTitle}"/>
                    <TextBlock Text="Current vs. maximum capacity per shelter" Style="{StaticResource CardSubtitle}"/>
                  </StackPanel>
                </Grid>
                <Border Height="1" Background="{StaticResource Border}" Margin="0,14,0,0"/>
                <!-- CollectionView renders occupancy bars per shelter -->
                <ItemsControl ItemsSource="{Binding Shelters}" Margin="18,16">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Margin="0,0,0,12">
                        <Grid  >
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                          <TextBlock Text="{Binding Name}"
                                 FontSize="13" FontWeight="Bold"
                                 Foreground="{StaticResource TextPrimary}"/>
                          <TextBlock Grid.Column="1"
                                 Text="{Binding OccupancyDisplay}"
                                 FontSize="12"
                                 Foreground="{StaticResource TextMuted}"/>
                        </Grid>
                        <!-- Progress bar -->
                        <Grid Height="6"  >
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                          <Border Background="{StaticResource Border}"
                                   CornerRadius="3" Height="6"/>
                          <Border Background="{Binding FillColor}"
                                   CornerRadius="3" Height="6"
                                   HorizontalAlignment="Left"
                                   Width="{Binding BarWidth}"/>
                        </Grid>
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <!-- Donut / status card -->
            <Border Grid.Column="1" Style="{StaticResource Card}">
              <StackPanel>
                <StackPanel Margin="18,18,18,0">
                  <TextBlock Text="Shelter Status" Style="{StaticResource CardTitle}"/>
                  <TextBlock Text="Distribution by current status" Style="{StaticResource CardSubtitle}"/>
                </StackPanel>
                <Border Height="1" Background="{StaticResource Border}" Margin="0,14,0,0"/>
                <StackPanel Margin="18,16">
                  <!-- Legend items -->
                  <Grid  >
<Grid.ColumnDefinitions><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0" Fill="{StaticResource Teal}"
                             Width="10" Height="10" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Open" FontSize="13"
                           Foreground="{StaticResource TextPrimary}" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="3 (60%)" FontSize="13"
                           FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                  </Grid>
                  <Grid  >
<Grid.ColumnDefinitions><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0" Fill="{StaticResource Accent}"
                             Width="10" Height="10" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Full" FontSize="13"
                           Foreground="{StaticResource TextPrimary}" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="2 (40%)" FontSize="13"
                           FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                  </Grid>
                  <Grid  >
<Grid.ColumnDefinitions><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0" Fill="{StaticResource BorderStrong}"
                             Width="10" Height="10" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="Closed / Maintenance" FontSize="13"
                           Foreground="{StaticResource TextPrimary}" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="2" Text="0" FontSize="13"
                           FontWeight="Bold" Foreground="{StaticResource TextPrimary}"/>
                  </Grid>
                </StackPanel>
              </StackPanel>
            </Border>
          </Grid>

          <!-- Shelter Table Card -->
          <Border Style="{StaticResource Card}">
            <StackPanel>
              <!-- card-header -->
              <Grid Margin="18,18,18,0"  >
<Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                  <TextBlock Text="Evacuation Shelters" Style="{StaticResource CardTitle}"/>
                  <TextBlock Text="Live occupancy status" Style="{StaticResource CardSubtitle}"/>
                </StackPanel>
                <Button Grid.Column="1" Content="View All →"
                        Style="{StaticResource BtnGhost}"
                        VerticalAlignment="Center"
                        Click="OnViewAllShelters"/>
              </Grid>
              <Border Height="1" Background="{StaticResource Border}" Margin="0,14,0,0"/>
              <!-- Table header -->
              <Grid  
                    Margin="16,12"
                    Background="{StaticResource TableHeaderBg}">
<Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <TextBlock Text="SHELTER NAME"  Style="{StaticResource TableHeader}"/>
                <TextBlock Grid.Column="1" Text="OCCUPANCY"   Style="{StaticResource TableHeader}"/>
                <TextBlock Grid.Column="2" Text="CAPACITY"    Style="{StaticResource TableHeader}"/>
                <TextBlock Grid.Column="3" Text="% FULL"      Style="{StaticResource TableHeader}"/>
                <TextBlock Grid.Column="4" Text="STATUS"      Style="{StaticResource TableHeader}"/>
              </Grid>
              <Border Height="1" Background="{StaticResource Border}"/>
              <!-- Rows -->
              <ItemsControl ItemsSource="{Binding Shelters}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid   Margin="16,0">
<Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding Name}" Style="{StaticResource TableCellBold}"/>
                      <TextBlock Grid.Column="1" Text="{Binding OccupancyDisplay}"
                             Style="{StaticResource TableCell}"/>
                      <TextBlock Grid.Column="2" Text="{Binding MaxCapacity}"
                             Style="{StaticResource TableCellMuted}"/>
                      <TextBlock Grid.Column="3" Text="{Binding PctFull}"
                             Style="{StaticResource TableCell}"
                             Foreground="{Binding PctColor}"/>
                      <Border Grid.Column="4"
                             Background="{Binding StatusBadgeBg}"
                             BorderBrush="Transparent"
                             CornerRadius="20" Padding="10,3"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center">
                        <TextBlock Text="{Binding Status}"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{Binding StatusTextColor}"/>
                      </Border>
                      <!-- Row separator -->
                      <Border Grid.ColumnSpan="5" Height="1"
                               Background="{StaticResource Border}"
                               VerticalAlignment="Bottom"/>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Dispatch Logs Card -->
          <Border Style="{StaticResource Card}">
            <StackPanel>
              <StackPanel Margin="18,18,18,0">
                <TextBlock Text="Recent Dispatch Logs" Style="{StaticResource CardTitle}"/>
                <TextBlock Text="Latest relief goods distributed" Style="{StaticResource CardSubtitle}"/>
              </StackPanel>
              <Border Height="1" Background="{StaticResource Border}" Margin="0,14,0,0"/>
              <Grid  
                    Margin="16,12"
                    Background="{StaticResource TableHeaderBg}">
<Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                <TextBlock Text="ITEM"               Style="{StaticResource TableHeader}"/>
                <TextBlock Grid.Column="1" Text="SHELTER DESTINATION" Style="{StaticResource TableHeader}"/>
                <TextBlock Grid.Column="2" Text="QTY"    Style="{StaticResource TableHeader}"/>
                <TextBlock Grid.Column="3" Text="DATE &amp; TIME" Style="{StaticResource TableHeader}"/>
              </Grid>
              <Border Height="1" Background="{StaticResource Border}"/>
              <ItemsControl ItemsSource="{Binding RecentDispatches}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid   Margin="16,0">
<Grid.ColumnDefinitions><ColumnDefinition Width="2*"/><ColumnDefinition Width="2*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="2*"/></Grid.ColumnDefinitions>
                      <TextBlock Text="{Binding ItemName}" Style="{StaticResource TableCellBold}"/>
                      <TextBlock Grid.Column="1" Text="{Binding Destination}"
                             Style="{StaticResource TableCellMuted}"/>
                      <TextBlock Grid.Column="2" Text="{Binding Qty}"
                             Style="{StaticResource TableCellBold}"/>
                      <TextBlock Grid.Column="3" Text="{Binding DateTimeDisplay}"
                             Style="{StaticResource TableCellMuted}"/>
                      <Border Grid.ColumnSpan="4" Height="1"
                               Background="{StaticResource Border}"
                               VerticalAlignment="Bottom"/>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>
    </Grid>
</UserControl>