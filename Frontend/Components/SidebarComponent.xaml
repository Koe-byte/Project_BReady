<UserControl x:Class="ProjectBReadyWPF.Frontend.Components.SidebarComponent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="250">
    
    <Border Background="#2C3E50">
        <StackPanel Margin="10,50,10,10">
            <TextBlock Text="B-READY" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <Button x:Name="BtnShelter" Content="Shelter Management" Margin="0,5" Height="40" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="BtnInventory" Content="Relief Inventory" Margin="0,5" Height="40" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button x:Name="BtnReport" Content="Situational Reports" Margin="0,5" Height="40" Background="#34495E" Foreground="White" BorderThickness="0" Cursor="Hand"/>

            <Separator Background="#7F8C8D" Margin="0,20"/>
            <Button x:Name="BtnLogout" Content="Logout" Height="40" Background="#C0392B" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </Border>
</UserControl>